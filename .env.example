# ============================================================
# MGTAB Detector V1 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development         # Set to 'production' on Railway
PORT=3001                    # Backend port

# --- Python Inference ---
PYTHON_PATH=python3                                          # Python executable
INFERENCE_SCRIPT_PATH=../inference/inference_v1.py           # Relative to /backend
MODEL_PATH=../inference/models/mlp_v1.pt                    # Trained MLP weights
NORMALIZATION_STATS_PATH=../inference/models/normalization_stats.json

# --- Feature Flags ---
ENABLE_MONGODB=false          # Set true if MongoDB URL is configured
ENABLE_FULL_GNN=false         # Phase 2: RGCN inference (not yet implemented)
ENABLE_LABSE=false            # Set true only if backend has >= 2GB RAM

# --- MongoDB (V2 — leave empty for V1) ---
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mgtab

# --- Security ---
LOG_LEVEL=info                # trace | debug | info | warn | error
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # Max requests per window per IP

# --- CORS ---
FRONTEND_URL=http://localhost:5173   # Set to Railway frontend URL in production
